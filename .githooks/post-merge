#!/bin/sh
# pinky-memory: post-merge hook for {slug}.brain repos
# Fires after every successful `git pull` that merges new commits.
# Can be installed in brain repos to trigger index rebuilds.
#
# To activate in a brain repo:
#   git config core.hooksPath .githooks

# Check if rebuild-index.py exists (bundled with the skill hub)
SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts"
if [ -f "$SCRIPT_DIR/rebuild-index.py" ]; then
  python3 "$SCRIPT_DIR/rebuild-index.py" "$(git rev-parse --show-toplevel)" 2>/dev/null || true
fi
